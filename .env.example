# ============================================================
# PhiloGPT — deployment configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# docker-compose.yml reads all values from here — never edit it directly.
# ============================================================

# --- Public URLs (browser-facing) ---
# The URL your users will hit for the chat frontend
FRONTEND_URL=https://philogpt.example.com
# The URL for the admin panel
ADMIN_URL=https://philogpt-admin.example.com
# The public URL of the API service (used by browsers and for CORS)
API_URL=https://philogpt-api.example.com

# --- Host ports (change if any conflict with other services, e.g. DSM) ---
API_PORT=5001
FRONTEND_PORT=3002
ADMIN_PORT=3001
MONGO_PORT=27017

# --- API secrets ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Admin seed account ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Seeding ---
# Seeds the database on first start if it is empty
SEED_ON_EMPTY_DB=true
# Set to true ONCE to wipe all data and reseed, then set back to false
PURGE_AND_RESEED=false

# --- Optional: OAuth providers (leave blank to disable) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Tuning ---
LOG_LEVEL=info
