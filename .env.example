# ============================================================
# PhiloGPT — deployment configuration
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# ============================================================

# --- Public URLs (browser-facing) ---
# The URL your users will hit for the chat frontend
FRONTEND_URL=https://philogpt.example.com
# The URL for the admin panel
ADMIN_URL=https://philogpt-admin.example.com
# The public URL of the backend API (used by browsers and for CORS)
API_URL=https://philogpt-api.example.com

# --- Backend secrets ---
JWT_SECRET=change-me-to-a-long-random-string

# --- Admin seed account ---
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me

# --- Optional: OAuth providers (leave blank to disable) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GITHUB_CLIENT_ID=
# GITHUB_CLIENT_SECRET=

# --- Tuning ---
LOG_LEVEL=info
