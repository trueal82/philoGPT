# ------------------------------------------------------------
# philoGPT - Repository-wide .gitignore
# Prevent committing secrets, local data, dependencies, and build output.
# ------------------------------------------------------------

# --- Secrets and environment files ---
.env
.env.*
!.env.example
!.env.sample
*.local
*.secret
*.secrets
*.key
*.pem
*.p12
*.pfx
*.crt
*.cer

# --- Dependency directories ---
node_modules/
**/node_modules/

# --- Package manager logs ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# --- Runtime logs and pid files ---
logs/
*.log
*.log.*
*.pid
*.pid.lock

# --- Local MongoDB and app data ---
.mongo-data/
.mongo.log
.mongo.log.*
*.db
*.sqlite
*.sqlite3

# --- Build / transpile output ---
dist/
build/
out/
.next/
.nuxt/
.cache/
.tmp/
tmp/
**/dist/
**/build/

# --- Test / coverage artifacts ---
coverage/
.nyc_output/
**/coverage/

# --- TypeScript incremental build info ---
*.tsbuildinfo

# --- Frontend tooling / caches ---
.parcel-cache/
.vite/
.eslintcache
.stylelintcache

# --- Docker / container local overrides ---
.docker/
.docker-data/

# --- OS files ---
.DS_Store
.AppleDouble
.LSOverride
Icon?
Thumbs.db
Desktop.ini

# --- IDE/editor files ---
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
.idea/
*.iml

# --- Misc temp files ---
*.tmp
*.temp
*.swp
*.swo
*~

# --- Archives / backups ---
*.zip
*.tar
*.tar.gz
*.tgz
*.bak
*.backup

# --- Optional local uploads/storage ---
uploads/
storage/
public/uploads/
admin-frontend/public/uploads/
backend/uploads/
